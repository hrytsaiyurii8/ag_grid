# Supabase project settings (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role secret (NOT the anon key) — Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# API port (optional)
PORT=3001

# Optional — frontend API URL (dev defaults to http://localhost:3001)
# VITE_API_BASE=http://localhost:3001

# Optional — removes Enterprise trial watermark in the browser console
# VITE_AG_GRID_LICENSE_KEY=your_ag_grid_license_key
